@model ML.Producto
@{
    ViewBag.Title = "Productos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Título -->
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold">Lista de Productos</h2>
        </div>
    </div>

    <!-- Botón Agregar -->
    <div class="row">
        <div class="col-12">
            <div class="mb-3">
                <button class="btn btn-success" onclick="location.href='@Url.Action("Formulario","Producto")'">
                    Agregar
                </button>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="row">
        <div class="col-12">
            @if (Model.Productos != null)
            {
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Categoría</th>
                            <th>Fecha Registro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ML.Producto producto in Model.Productos)
                        {
                            <tr>
                                <td>@producto.Nombre</td>
                                <td>@producto.Descripcion</td>
                                <td>@producto.Precio</td>
                                <td>@producto.Stock</td>
                                <td>@producto.Categoria</td>
                                <td>
                                    @(producto.FechaRegistro != null
                                        ? producto.FechaRegistro.ToString("dd/MM/yyyy")
                                        : "Sin fecha")
                                </td>
                                <td>
                                    <button class="btn btn-warning btn-sm"
                                            onclick="location.href='@Url.Action("Formulario","Producto", new { idProducto = producto.IdProducto })'">
                                        Editar
                                    </button>
                                    @using (Html.BeginForm("Delete", "Producto", new { idProducto = producto.IdProducto }, FormMethod.Post))
                                    {
                                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning">
                    No se encontraron productos registrados.
                </div>
            }
        </div>
    </div>
</div>
